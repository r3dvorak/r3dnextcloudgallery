    <description>R3D Nextcloud Gallery package for Joomla 6. Please enable both plugins after install.</description>
    <blockChildUninstall>false</blockChildUninstall>

    <files>
        <file type="plugin" id="r3dnextcloudgallery" group="fields">plg_fields_r3dnextcloudgallery.zip</file>
        <file type="plugin" id="r3dnextcloudgallery_yootheme" group="system">plg_system_r3dnextcloudgallery_yootheme.zip</file>
    </files>

    <updateservers>
        <server type="extension" priority="1" name="R3D Nextcloud Gallery Update Server">https://extensions.r3d.de/joomlaextensions/updates/pkg_r3dnextcloudgallery.xml</server>
